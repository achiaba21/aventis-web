# Configuration d'environnement Asfar
# Premier lancement :  cp .env.example .env  (puis ajuster les valeurs)
# Le fichier .env n'est PAS versionné. Toute clé absente ou vide
# retombe sur sa valeur par défaut (celles indiquées ci-dessous).

# Schéma réseau : true = https/wss, false = http/ws (dev local)
USE_TLS=true

# Backend Spring Boot
SERVER_HOST=192.168.1.7
SERVER_PORT=7565

# Clé API Stadia Maps (tuiles carte) — vide = tuiles sans clé
STADIA_KEY=
