"<!DOCTYPE html>\n<html lang=\"fr\"><head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n  <title>Asfar — Prototype<\u002Ftitle>\n  <style>/* Asfar — Dark Premium Design System */\n\n:root {\n  --bg: #0A0A0B;\n  --bg-elev-1: #131316;\n  --bg-elev-2: #1C1C20;\n  --bg-elev-3: #25252B;\n  --line: rgba(255,255,255,0.08);\n  --line-strong: rgba(255,255,255,0.14);\n\n  --text: #F5F5F7;\n  --text-2: #B8B8BE;\n  --text-3: #76767E;\n  --text-dim: #4A4A52;\n\n  /* Accent — warm gold, evokes hospitality + African luxe */\n  --accent: #E8B86B;\n  --accent-2: #C99650;\n  --accent-soft: rgba(232, 184, 107, 0.14);\n\n  --success: #4ADE80;\n  --warn: #F4B740;\n  --danger: #F87171;\n  --info: #60A5FA;\n\n  --radius-sm: 10px;\n  --radius-md: 14px;\n  --radius-lg: 20px;\n  --radius-xl: 28px;\n\n  --font: -apple-system, \"SF Pro Display\", \"SF Pro Text\", system-ui, sans-serif;\n}\n\n* { box-sizing: border-box; }\n\nhtml, body {\n  margin: 0;\n  padding: 0;\n  font-family: var(--font);\n  background: #0E0E10;\n  color: var(--text);\n  -webkit-font-smoothing: antialiased;\n}\n\n/* ────── App-level utilities ────── */\n.asfar { font-family: var(--font); color: var(--text); }\n\n.asfar .screen {\n  width: 100%; height: 100%;\n  background: var(--bg);\n  display: flex; flex-direction: column;\n  overflow: hidden;\n  position: relative;\n}\n\n.asfar .scroll {\n  flex: 1; overflow-y: auto;\n  -webkit-overflow-scrolling: touch;\n  scrollbar-width: none;\n}\n.asfar .scroll::-webkit-scrollbar { display: none; }\n\n.asfar .stack { display: flex; flex-direction: column; }\n.asfar .row { display: flex; align-items: center; }\n\n/* Typography */\n.asfar .t-display { font-size: 32px; font-weight: 700; letter-spacing: -0.6px; line-height: 1.05; }\n.asfar .t-h1 { font-size: 26px; font-weight: 700; letter-spacing: -0.4px; line-height: 1.15; }\n.asfar .t-h2 { font-size: 20px; font-weight: 700; letter-spacing: -0.3px; line-height: 1.2; }\n.asfar .t-h3 { font-size: 17px; font-weight: 600; letter-spacing: -0.2px; }\n.asfar .t-body { font-size: 15px; line-height: 1.45; color: var(--text-2); }\n.asfar .t-small { font-size: 13px; color: var(--text-2); }\n.asfar .t-mono-num { font-variant-numeric: tabular-nums; font-feature-settings: \"tnum\"; }\n.asfar .t-eyebrow {\n  font-size: 11px; font-weight: 600; letter-spacing: 1.2px;\n  text-transform: uppercase; color: var(--text-3);\n}\n\n/* Buttons */\n.asfar .btn {\n  display: inline-flex; align-items: center; justify-content: center;\n  gap: 8px; padding: 14px 18px;\n  border: none; border-radius: 14px;\n  font-family: var(--font); font-size: 16px; font-weight: 600;\n  cursor: pointer; transition: transform .12s ease, opacity .12s;\n  letter-spacing: -0.1px;\n}\n.asfar .btn:active { transform: scale(0.97); }\n.asfar .btn-primary {\n  background: var(--accent); color: #1A1206;\n}\n.asfar .btn-secondary {\n  background: var(--bg-elev-2); color: var(--text);\n  border: 1px solid var(--line);\n}\n.asfar .btn-ghost {\n  background: transparent; color: var(--text);\n}\n.asfar .btn-block { width: 100%; }\n.asfar .btn-lg { padding: 16px 20px; font-size: 17px; border-radius: 16px; }\n.asfar .btn-sm { padding: 9px 14px; font-size: 13px; border-radius: 10px; }\n\n/* Cards */\n.asfar .card {\n  background: var(--bg-elev-1);\n  border: 1px solid var(--line);\n  border-radius: var(--radius-lg);\n}\n\n/* Chips */\n.asfar .chip {\n  display: inline-flex; align-items: center; gap: 6px;\n  padding: 7px 12px; border-radius: 999px;\n  background: var(--bg-elev-2); border: 1px solid var(--line);\n  font-size: 13px; color: var(--text-2);\n  cursor: pointer; user-select: none;\n  white-space: nowrap;\n}\n.asfar .chip-active {\n  background: var(--accent-soft);\n  color: var(--accent);\n  border-color: rgba(232, 184, 107, 0.3);\n}\n\n/* Inputs */\n.asfar .input {\n  width: 100%;\n  background: var(--bg-elev-2);\n  border: 1px solid var(--line);\n  color: var(--text);\n  padding: 14px 16px; border-radius: 12px;\n  font-family: var(--font); font-size: 15px;\n  outline: none;\n}\n.asfar .input::placeholder { color: var(--text-3); }\n.asfar .input:focus { border-color: var(--accent); }\n\n/* Tab bar (bottom) */\n.asfar .tabbar {\n  display: flex; justify-content: space-around;\n  padding: 8px 4px 24px;\n  background: rgba(10,10,11,0.85);\n  backdrop-filter: blur(20px) saturate(180%);\n  -webkit-backdrop-filter: blur(20px) saturate(180%);\n  border-top: 1px solid var(--line);\n}\n.asfar .tab {\n  flex: 1; display: flex; flex-direction: column; align-items: center; gap: 3px;\n  padding: 8px 4px; cursor: pointer;\n  color: var(--text-3); font-size: 10px; font-weight: 500;\n}\n.asfar .tab.active { color: var(--accent); }\n.asfar .tab svg { display: block; }\n\n/* Top nav */\n.asfar .topnav {\n  display: flex; align-items: center; justify-content: space-between;\n  padding: 10px 18px 12px;\n}\n\n/* Avatar */\n.asfar .avatar {\n  width: 36px; height: 36px; border-radius: 999px;\n  background: linear-gradient(135deg, #C99650, #5A3A1A);\n  display: flex; align-items: center; justify-content: center;\n  font-size: 14px; font-weight: 600; color: #fff;\n  flex-shrink: 0;\n  background-size: cover; background-position: center;\n}\n\n/* List rows */\n.asfar .listrow {\n  display: flex; align-items: center; gap: 12px;\n  padding: 14px 16px;\n  border-bottom: 1px solid var(--line);\n}\n.asfar .listrow:last-child { border-bottom: none; }\n\n/* Badges */\n.asfar .badge {\n  display: inline-flex; align-items: center; gap: 4px;\n  padding: 3px 8px; border-radius: 6px;\n  font-size: 11px; font-weight: 600; letter-spacing: 0.2px;\n}\n.asfar .badge-success { background: rgba(74,222,128,0.14); color: #6EE7A0; }\n.asfar .badge-warn { background: rgba(244,183,64,0.14); color: var(--warn); }\n.asfar .badge-info { background: rgba(96,165,250,0.14); color: var(--info); }\n.asfar .badge-danger { background: rgba(248,113,113,0.14); color: var(--danger); }\n.asfar .badge-accent { background: var(--accent-soft); color: var(--accent); }\n.asfar .badge-neutral { background: var(--bg-elev-3); color: var(--text-2); }\n\n/* Image placeholder */\n.asfar .img-ph {\n  background: linear-gradient(135deg, #2A2118 0%, #181410 60%, #0F0C08 100%);\n  position: relative;\n  overflow: hidden;\n}\n.asfar .img-ph::after {\n  content: \"\";\n  position: absolute; inset: 0;\n  background: radial-gradient(circle at 30% 20%, rgba(232,184,107,0.18), transparent 60%),\n              radial-gradient(circle at 80% 90%, rgba(201,150,80,0.12), transparent 50%);\n}\n.asfar .img-ph[data-tone=\"2\"] {\n  background: linear-gradient(135deg, #1F2A24 0%, #131A18 60%, #0A100E 100%);\n}\n.asfar .img-ph[data-tone=\"2\"]::after {\n  background: radial-gradient(circle at 70% 30%, rgba(74,222,128,0.13), transparent 60%);\n}\n.asfar .img-ph[data-tone=\"3\"] {\n  background: linear-gradient(135deg, #2A1F2A 0%, #1A131A 60%, #100A10 100%);\n}\n.asfar .img-ph[data-tone=\"3\"]::after {\n  background: radial-gradient(circle at 30% 70%, rgba(192,132,252,0.13), transparent 60%);\n}\n.asfar .img-ph[data-tone=\"4\"] {\n  background: linear-gradient(135deg, #1F2530 0%, #131820 60%, #0A0E14 100%);\n}\n.asfar .img-ph[data-tone=\"4\"]::after {\n  background: radial-gradient(circle at 50% 30%, rgba(96,165,250,0.13), transparent 60%);\n}\n\n/* Dividers */\n.asfar .divider { height: 1px; background: var(--line); margin: 16px 18px; }\n\n/* Subtle shimmer for loading mocks */\n@keyframes asfar-pulse {\n  0%, 100% { opacity: 1; }\n  50% { opacity: 0.6; }\n}\n\n/* Fade enter */\n@keyframes asfar-fade-up {\n  from { opacity: 0; transform: translateY(6px); }\n  to { opacity: 1; transform: translateY(0); }\n}\n.asfar .fade-in { animation: asfar-fade-up .25s ease both; }\n\n/* Sparkbar (mini bar chart) */\n.asfar .sparkbar { display: flex; align-items: flex-end; gap: 4px; height: 56px; }\n.asfar .sparkbar > div {\n  flex: 1; background: var(--bg-elev-3); border-radius: 3px;\n  transition: background .2s;\n}\n.asfar .sparkbar > div.hi { background: var(--accent); }\n\n/* Section header */\n.asfar .section-h {\n  display: flex; align-items: baseline; justify-content: space-between;\n  padding: 18px 18px 10px;\n}\n\n/* Map placeholder */\n.asfar .map-ph {\n  background:\n    linear-gradient(180deg, #0F1416 0%, #0A0E10 100%);\n  position: relative;\n  overflow: hidden;\n}\n.asfar .map-ph::before {\n  content: \"\";\n  position: absolute; inset: 0;\n  background-image:\n    linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),\n    linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);\n  background-size: 28px 28px;\n}\n.asfar .map-ph::after {\n  content: \"\";\n  position: absolute; inset: 0;\n  background:\n    radial-gradient(ellipse 120px 80px at 30% 40%, rgba(232,184,107,0.06), transparent),\n    radial-gradient(ellipse 200px 120px at 70% 65%, rgba(255,255,255,0.03), transparent);\n}\n<\u002Fstyle>\n  <style>\n    body { background: #08080A; min-height: 100vh; overflow-x: hidden; }\n    .canvas-bg { position: fixed; inset: 0; pointer-events: none; z-index: 0;\n      background:\n        radial-gradient(ellipse 800px 500px at 20% 10%, rgba(232,184,107,0.05), transparent 60%),\n        radial-gradient(ellipse 700px 600px at 80% 70%, rgba(94,108,255,0.04), transparent 60%); }\n    .canvas-grid { position: fixed; inset: 0; pointer-events: none; z-index: 0; opacity: 0.4;\n      background-image:\n        linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),\n        linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);\n      background-size: 60px 60px; }\n    .stage { position: relative; z-index: 1; padding: 60px 40px 80px; min-height: 100vh; }\n    .stage-header { max-width: 1400px; margin: 0 auto 56px; }\n    .stage-title { font-family: var(--font); font-size: 38px; font-weight: 700; letter-spacing: -1px;\n      color: #F5F5F7; margin: 0 0 8px; }\n    .stage-title em { font-style: italic; font-weight: 400; color: var(--accent); }\n    .stage-sub { font-family: var(--font); font-size: 16px; color: rgba(245,245,247,0.55);\n      max-width: 600px; line-height: 1.5; }\n    .logo-mark { display: inline-flex; align-items: center; gap: 10px; font-family: var(--font); margin-bottom: 24px; }\n    .logo-mark > div:first-child { width: 32px; height: 32px; border-radius: 9px;\n      background: var(--accent); color: #1A1206; display: flex; align-items: center; justify-content: center;\n      font-weight: 800; font-size: 16px; font-style: italic; }\n    .logo-mark > div:last-child { font-size: 20px; font-weight: 700; letter-spacing: -0.4px; color: #F5F5F7; }\n    .phones-row { display: flex; gap: 60px; justify-content: center; flex-wrap: wrap;\n      max-width: 1500px; margin: 0 auto; align-items: flex-start; }\n    .phone-slot { display: flex; flex-direction: column; align-items: center; }\n    .phone-label { font-family: var(--font); margin-bottom: 18px; text-align: center; }\n    .phone-label-eyebrow { font-size: 10px; font-weight: 700; letter-spacing: 1.4px;\n      text-transform: uppercase; color: var(--accent); margin-bottom: 6px; }\n    .phone-label-title { font-size: 22px; font-weight: 700; letter-spacing: -0.4px;\n      color: #F5F5F7; margin-bottom: 4px; }\n    .phone-label-sub { font-size: 13px; color: rgba(245,245,247,0.5); }\n    .phone-wrap { transform: scale(0.78); transform-origin: top center; margin-bottom: -180px; }\n    @media (max-width: 1500px) { .phone-wrap { transform: scale(0.7); margin-bottom: -240px; } }\n    @media (max-width: 1300px) { .phones-row { gap: 36px; }\n      .phone-wrap { transform: scale(0.62); margin-bottom: -310px; } }\n    @media (max-width: 1100px) { .phones-row { flex-direction: column; align-items: center; gap: 30px; }\n      .phone-wrap { transform: none; margin-bottom: 0; }\n      .stage { padding: 40px 20px 60px; }\n      .stage-title { font-size: 28px; } }\n    .single-wrap { display: flex; justify-content: center; padding: 20px 0; }\n    .footer { max-width: 1400px; margin: 100px auto 20px; padding-top: 30px;\n      border-top: 1px solid rgba(255,255,255,0.06); font-family: var(--font); font-size: 12px;\n      color: rgba(245,245,247,0.4); text-align: center; }\n  <\u002Fstyle>\n  <script src=\"41c265c4-4847-4130-a508-1afbe054de3d\" integrity=\"sha384-hD6/rw4ppMLGNu3tX5cjIb+uRZ7UkRJ6BPkLpg4hAu/6onKUg4lLsHAs9EBPT82L\" crossorigin=\"anonymous\"><\u002Fscript>\n  <script src=\"e34c7dfe-a3be-4df5-a6ee-b5db67b1358c\" integrity=\"sha384-u6aeetuaXnQ38mYT8rp6sbXaQe3NL9t+IBXmnYxwkUI2Hw4bsp2Wvmx4yRQF1uAm\" crossorigin=\"anonymous\"><\u002Fscript>\n  <script src=\"bb1c6578-353b-4d4a-9765-7c1dcc6934b5\" integrity=\"sha384-m08KidiNqLdpJqLq95G/LEi8Qvjl/xUYll3QILypMoQ65QorJ9Lvtp2RXYGBFj1y\" crossorigin=\"anonymous\"><\u002Fscript>\n<\u002Fhead>\n<body>\n  <div class=\"canvas-bg\"><\u002Fdiv>\n  <div class=\"canvas-grid\"><\u002Fdiv>\n  \n  <div id=\"root\"><\u002Fdiv>\n\n  <script type=\"text/babel\" src=\"fc335aef-a159-4b20-80d0-6cc3444e5470\"><\u002Fscript>\n  <script type=\"text/babel\" src=\"328b7fcb-4d57-4768-8b11-24ef0604cebf\"><\u002Fscript>\n  <script type=\"text/babel\" src=\"c4630092-8870-4ca2-a5af-43d2df3a3e76\"><\u002Fscript>\n  <script type=\"text/babel\" src=\"a926aadc-d663-4d6d-bfae-046265b4de75\"><\u002Fscript>\n  <script type=\"text/babel\" src=\"da2dbb3d-d5cb-45ac-afd4-0c75b4b47146\"><\u002Fscript>\n  <script type=\"text/babel\" src=\"72a7a25a-1b16-49e8-b573-1f56555c3c15\"><\u002Fscript>\n  <script type=\"text/babel\" src=\"3b242f91-f934-46c4-b52e-d2121d4b60ad\"><\u002Fscript>\n  <script type=\"text/babel\" src=\"9537d89a-cd68-47ef-8083-9872f596c719\"><\u002Fscript>\n\n  <script type=\"text/babel\">\n    const { useEffect: _useEffect } = React;\n\n    const TWEAK_DEFAULTS = /*EDITMODE-BEGIN*/{\n      \"view\": \"all\",\n      \"accent\": \"#E8B86B\"\n    }/*EDITMODE-END*/;\n\n    function PhoneFrame({ role }) {\n      return (\n        <IOSDevice dark={true} width={402} height={874}>\n          <PhoneApp initialRole={role}/>\n        <\u002FIOSDevice>\n      );\n    }\n\n    function PhoneSlot({ role, eyebrow, title, sub }) {\n      return (\n        <div className=\"phone-slot\">\n          <div className=\"phone-label\">\n            <div className=\"phone-label-eyebrow\">{eyebrow}<\u002Fdiv>\n            <div className=\"phone-label-title\" data-screen-label={title}>{title}<\u002Fdiv>\n            <div className=\"phone-label-sub\">{sub}<\u002Fdiv>\n          <\u002Fdiv>\n          <div className=\"phone-wrap\">\n            <PhoneFrame role={role}/>\n          <\u002Fdiv>\n        <\u002Fdiv>\n      );\n    }\n\n    function Root() {\n      const [t, setTweak] = useTweaks(TWEAK_DEFAULTS);\n\n      _useEffect(() => {\n        document.documentElement.style.setProperty('--accent', t.accent);\n        const r = parseInt(t.accent.slice(1,3), 16);\n        const g = parseInt(t.accent.slice(3,5), 16);\n        const b = parseInt(t.accent.slice(5,7), 16);\n        document.documentElement.style.setProperty('--accent-soft', `rgba(${r},${g},${b},0.14)`);\n      }, [t.accent]);\n\n      return (\n        <>\n          <div className=\"stage\">\n            <div className=\"stage-header\">\n              <div className=\"logo-mark\"><div>A<\u002Fdiv><div>asfar<\u002Fdiv><\u002Fdiv>\n              <h1 className=\"stage-title\">Trois faces, <em>une plateforme.<\u002Fem><\u002Fh1>\n              <div className=\"stage-sub\">\n                Asfar relie les voyageurs, les propriétaires d'appartements meublés et les démarcheurs\n                qui apportent les clients. Trois interfaces dédiées, une seule expérience fluide. Côte d'Ivoire · FCFA.\n              <\u002Fdiv>\n            <\u002Fdiv>\n\n            {t.view === \"all\" ? (\n              <div className=\"phones-row\">\n                <PhoneSlot role=\"locataire\" eyebrow=\"RÔLE 1\" title=\"Locataire\"\n                  sub=\"Recherche · Réservation · Paiement\"/>\n                <PhoneSlot role=\"proprietaire\" eyebrow=\"RÔLE 2\" title=\"Propriétaire\"\n                  sub=\"Annonces · Finances P&L · Réservations\"/>\n                <PhoneSlot role=\"demarcheur\" eyebrow=\"RÔLE 3\" title=\"Démarcheur\"\n                  sub=\"Référer clients · Suivre commissions\"/>\n              <\u002Fdiv>\n            ) : (\n              <div className=\"single-wrap\">\n                <PhoneFrame role={t.view}/>\n              <\u002Fdiv>\n            )}\n\n            <div className=\"footer\">\n              Asfar · Prototype interactif · Activez Tweaks pour basculer entre rôles\n            <\u002Fdiv>\n          <\u002Fdiv>\n\n          <TweaksPanel title=\"Tweaks\">\n            <TweakSection label=\"Vue\">\n              <TweakSelect label=\"Affichage\" value={t.view}\n                options={[\n                  { value: \"all\", label: \"3 rôles côte à côte\" },\n                  { value: \"locataire\", label: \"Locataire seul\" },\n                  { value: \"proprietaire\", label: \"Propriétaire seul\" },\n                  { value: \"demarcheur\", label: \"Démarcheur seul\" },\n                ]}\n                onChange={(v) => setTweak('view', v)}/>\n            <\u002FTweakSection>\n\n            <TweakSection label=\"Couleur d'accent\">\n              <TweakColor label=\"Accent\" value={t.accent}\n                options={[\"#E8B86B\", \"#4ADE80\", \"#5E6CFF\", \"#F87171\", \"#C084FC\"]}\n                onChange={(v) => setTweak('accent', v)}/>\n            <\u002FTweakSection>\n          <\u002FTweaksPanel>\n        <\u002F>\n      );\n    }\n\n    ReactDOM.createRoot(document.getElementById('root')).render(<Root/>);\n  <\u002Fscript>\n\n\n<\u002Fbody><\u002Fhtml>"